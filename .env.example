# Runtime
NODE_ENV=production
PORT=3000

# PostgreSQL - Railway can inject this automatically when a Postgres service is attached.
DATABASE_URL=postgresql://user:password@host:5432/database

# Session security. Use a long random value in every environment.
JWT_SECRET=replace-with-a-long-random-secret

# Temporary homologation mode. Keep false in real production after OAuth is configured.
DEMO_AUTH_ENABLED=false

# Email-code authentication. The e-mail must exist and be active in Gestao de Acesso.
EMAIL_AUTH_ENABLED=true
EMAIL_FROM=TechBoard+ <noreply@techdmais.com.br>
RESEND_API_KEY=
# Use "provider" in production. Use "log" only for local tests.
EMAIL_DELIVERY_MODE=provider

# Legacy OAuth / login portal variables. Leave empty when using e-mail code auth.
VITE_APP_ID=replace-with-app-id
VITE_OAUTH_PORTAL_URL=https://replace-with-oauth-portal
OAUTH_SERVER_URL=https://replace-with-oauth-server
OWNER_OPEN_ID=replace-with-owner-open-id

# Optional built-in service integrations from the template.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional frontend Google Maps proxy integration. These are baked into the
# Vite build and must be present before building the Docker image if used.
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Optional frontend analytics.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
